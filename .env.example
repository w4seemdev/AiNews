# AI Pulse environment variables
#
# Copy this file to .env and fill in real values for local development.
# Never commit a real .env file.

# Optional. Enables the LLM enrichment step in scripts/enrich.mjs.
# If unset, the news pipeline runs unchanged and publishes the raw collected cards.
# In CI this is provided via the GitHub Actions secret ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=
